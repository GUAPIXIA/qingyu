{
  "name": "qingyu",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "轻语 - 轻量级 AI 角色扮演客户端",
  "author": "QingYu",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "node electron-build.mjs && concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "electron:build": "node electron-build.mjs && vite build && electron-builder --win",
    "electron:preview": "node electron-build.mjs && vite build && electron .",
    "lint": "eslint .",
    "check": "tsc -b --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.511.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.3.0",
    "react-virtuoso": "^4.18.11",
    "rehype-highlight": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^3.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.6",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.15.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.qingyu.app",
    "productName": "轻语",
    "directories": {
      "output": "release-v2"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "轻语"
    }
  }
}
